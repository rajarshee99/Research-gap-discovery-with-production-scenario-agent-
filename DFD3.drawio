  <diagram id="Z6XoD3PYLY6h6NdSi2fk" name="Page-2">
    <mxGraphModel dx="872" dy="547" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="&lt;h1&gt;Semantic Chunking&lt;/h1&gt;&lt;h2&gt;Purpose&lt;/h2&gt;&lt;p&gt;Transforms parsed PDF text into retrieval-optimized chunks for RAG while preserving semantic context.&lt;/p&gt;&lt;h2&gt;Stack&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;code&gt;LangChain Experimental SemanticChunker&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;code&gt;HuggingFaceEmbeddings&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Model: &lt;code&gt;BAAI/bge-large-en-v1.5&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h2&gt;Workflow&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Parsed PDF&#xa;    ↓&#xa;SemanticChunker&#xa;    ↓&#xa;Chunk Creation&#xa;    ↓&#xa;Embedding&#xa;    ↓&#xa;Pinecone&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h2&gt;Semantic Chunking Logic&lt;/h2&gt;&lt;ol&gt;&lt;li&gt;&lt;p&gt;Split document into sentences.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Generate sentence embeddings using BGE-Large.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Compute semantic distance between neighboring sentences.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Detect topic shifts using:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;breakpoint_threshold_type=&quot;percentile&quot;&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Create chunks at high-distance boundaries.&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;p&gt;Example:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Introduction      → Chunk 1&#xa;Methodology       → Chunk 2&#xa;Results           → Chunk 3&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h2&gt;Fallback Strategy&lt;/h2&gt;&lt;p&gt;Applied when:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Semantic chunking fails&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Only 0–1 chunks are produced&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;PDF/OCR text quality is poor&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3&gt;Level 1: Paragraph Split&lt;/h3&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Split on &lt;code&gt;\n\n&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Repack into ~1200-character chunks&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3&gt;Level 2: Sentence Split&lt;/h3&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Split on sentence boundaries&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Repack into ~1200-character chunks&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3&gt;Level 3: Character Split&lt;/h3&gt;&lt;p&gt;Forced chunking:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Chunk Size = 1200 chars&#xa;Overlap   = 200 chars&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;Example:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;0–1200&#xa;1000–2200&#xa;2000–3200&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h2&gt;Output&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;{&#xa;    &quot;chunk_id&quot;: &quot;uuid&quot;,&#xa;    &quot;text&quot;: &quot;chunk content&quot;,&#xa;    &quot;metadata&quot;: {&#xa;        &quot;source&quot;: &quot;paper.pdf&quot;,&#xa;        &quot;filename&quot;: &quot;paper.pdf&quot;,&#xa;        &quot;chunk_index&quot;: 0&#xa;    }&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h2&gt;Design Goals&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Preserve semantic meaning&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Improve RAG retrieval accuracy&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Prevent single-chunk documents&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Handle noisy OCR/PDF extraction&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Guarantee chunk generation&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Ensure deterministic fallback behavior&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h2&gt;Configuration&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Embedding Model : BAAI/bge-large-en-v1.5&#xa;Boundary Method : Percentile Semantic Distance&#xa;Fallback Size   : 1200 chars&#xa;Overlap         : 200 chars&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h2&gt;Benefits&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Section-aware retrieval&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Better literature review search&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Improved research-gap discovery&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Higher-quality context for LangGraph agents&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Robust academic PDF processing&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;" link="&lt;h1&gt;Semantic Chunking&lt;/h1&gt;&lt;h2&gt;Purpose&lt;/h2&gt;&lt;p&gt;Transforms parsed PDF text into retrieval-optimized chunks for RAG while preserving semantic context.&lt;/p&gt;&lt;h2&gt;Stack&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;code&gt;LangChain Experimental SemanticChunker&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;code&gt;HuggingFaceEmbeddings&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Model: &lt;code&gt;BAAI/bge-large-en-v1.5&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h2&gt;Workflow&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Parsed PDF&#xa;    ↓&#xa;SemanticChunker&#xa;    ↓&#xa;Chunk Creation&#xa;    ↓&#xa;Embedding&#xa;    ↓&#xa;Pinecone&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h2&gt;Semantic Chunking Logic&lt;/h2&gt;&lt;ol&gt;&lt;li&gt;&lt;p&gt;Split document into sentences.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Generate sentence embeddings using BGE-Large.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Compute semantic distance between neighboring sentences.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Detect topic shifts using:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;breakpoint_threshold_type=&quot;percentile&quot;&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Create chunks at high-distance boundaries.&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;p&gt;Example:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Introduction      → Chunk 1&#xa;Methodology       → Chunk 2&#xa;Results           → Chunk 3&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h2&gt;Fallback Strategy&lt;/h2&gt;&lt;p&gt;Applied when:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Semantic chunking fails&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Only 0–1 chunks are produced&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;PDF/OCR text quality is poor&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3&gt;Level 1: Paragraph Split&lt;/h3&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Split on &lt;code&gt;\n\n&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Repack into ~1200-character chunks&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3&gt;Level 2: Sentence Split&lt;/h3&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Split on sentence boundaries&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Repack into ~1200-character chunks&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3&gt;Level 3: Character Split&lt;/h3&gt;&lt;p&gt;Forced chunking:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Chunk Size = 1200 chars&#xa;Overlap   = 200 chars&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;Example:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;0–1200&#xa;1000–2200&#xa;2000–3200&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h2&gt;Output&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;{&#xa;    &quot;chunk_id&quot;: &quot;uuid&quot;,&#xa;    &quot;text&quot;: &quot;chunk content&quot;,&#xa;    &quot;metadata&quot;: {&#xa;        &quot;source&quot;: &quot;paper.pdf&quot;,&#xa;        &quot;filename&quot;: &quot;paper.pdf&quot;,&#xa;        &quot;chunk_index&quot;: 0&#xa;    }&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h2&gt;Design Goals&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Preserve semantic meaning&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Improve RAG retrieval accuracy&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Prevent single-chunk documents&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Handle noisy OCR/PDF extraction&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Guarantee chunk generation&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Ensure deterministic fallback behavior&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h2&gt;Configuration&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Embedding Model : BAAI/bge-large-en-v1.5&#xa;Boundary Method : Percentile Semantic Distance&#xa;Fallback Size   : 1200 chars&#xa;Overlap         : 200 chars&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h2&gt;Benefits&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Section-aware retrieval&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Better literature review search&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Improved research-gap discovery&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Higher-quality context for LangGraph agents&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Robust academic PDF processing&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;" id="cVSO5oJmDii94UQ-5USj-1">
          <mxCell parent="1" style="text;whiteSpace=wrap;html=1;fontSize=14;" vertex="1">
            <mxGeometry height="1900" width="560" x="20" y="170" as="geometry" />
          </mxCell>
        </UserObject>
