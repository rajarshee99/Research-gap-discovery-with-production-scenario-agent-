  <diagram id="uxf7cCXJgarN27a5cMH4" name="Page-3">
    <mxGraphModel dx="872" dy="547" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="&lt;h1&gt;PDF Parser&lt;/h1&gt;&lt;h2&gt;Purpose&lt;/h2&gt;&lt;p&gt;Extracts clean text and metadata from scientific PDFs using PyMuPDF (&lt;code&gt;fitz&lt;/code&gt;) and converts them into a standardized format for downstream chunking and indexing.&lt;/p&gt;&lt;h2&gt;Stack&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;PyMuPDF (&lt;code&gt;fitz&lt;/code&gt;)&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Regex-based text normalization&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Structured logging&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h2&gt;Workflow&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;PDF File&#xa;    ↓&#xa;PyMuPDF&#xa;    ↓&#xa;Page-by-Page Extraction&#xa;    ↓&#xa;Text Normalization&#xa;    ↓&#xa;Metadata Extraction&#xa;    ↓&#xa;Parsed Document&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h2&gt;Parsing Logic&lt;/h2&gt;&lt;h3&gt;1. Open PDF&lt;/h3&gt;&lt;p&gt;Loads PDF using:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;fitz.open(pdf_path)&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h3&gt;2. Extract Metadata&lt;/h3&gt;&lt;p&gt;Reads PDF metadata dictionary:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;title&#xa;author&#xa;page_count&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;Fallbacks:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;title → title or Title&#xa;author → author or Author&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h3&gt;3. Page-by-Page Text Extraction&lt;/h3&gt;&lt;p&gt;Processes pages sequentially to preserve document order.&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;for page in document:&#xa;    page.get_text(&quot;text&quot;)&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h3&gt;4. Text Normalization&lt;/h3&gt;&lt;p&gt;Normalizes extracted text by:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Converting Windows newlines → &lt;code&gt;\n&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Collapsing tabs/multiple spaces → single space&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Reducing 3+ blank lines → 2 blank lines&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Removing leading/trailing whitespace&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;Example:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Raw:&#xa;Text      here&#xa;&#xa;&#xa;&#xa;More text&#xa;&#xa;Normalized:&#xa;Text here&#xa;&#xa;More text&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h3&gt;5. Empty Page Handling&lt;/h3&gt;&lt;p&gt;Skips pages that contain:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;&quot;&quot;&#xa;None&#xa;Whitespace-only content&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h3&gt;6. Merge Pages&lt;/h3&gt;&lt;p&gt;Combines all valid pages:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;full_text = &quot;\n\n&quot;.join(pages_text)&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h2&gt;Output&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;{&#xa;    &quot;full_text&quot;: &quot;...&quot;,&#xa;    &quot;metadata&quot;: {&#xa;        &quot;title&quot;: &quot;...&quot;,&#xa;        &quot;author&quot;: &quot;...&quot;,&#xa;        &quot;page_count&quot;: 12&#xa;    }&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h2&gt;Error Handling&lt;/h2&gt;&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Failure&lt;/th&gt;&lt;th&gt;Action&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;Missing PyMuPDF&lt;/td&gt;&lt;td&gt;RuntimeError&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Missing PDF&lt;/td&gt;&lt;td&gt;FileNotFoundError&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Corrupted PDF&lt;/td&gt;&lt;td&gt;ValueError&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Metadata failure&lt;/td&gt;&lt;td&gt;Continue parsing&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Page load failure&lt;/td&gt;&lt;td&gt;Skip page&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Text extraction failure&lt;/td&gt;&lt;td&gt;Skip page&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;h2&gt;Pipeline Position&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;PDF Upload&#xa;    ↓&#xa;pdf_ingestion.py&#xa;    ↓&#xa;parser.py&#xa;    ↓&#xa;semantic_chunker.py&#xa;    ↓&#xa;embedder.py&#xa;    ↓&#xa;pinecone_upsert.py&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h2&gt;Design Goals&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Preserve page order&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Extract complete document text&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Remove extraction noise&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Handle malformed PDFs gracefully&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Preserve document metadata&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Produce chunker-ready output&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h2&gt;Current Output Schema&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Input  : PDF File&#xa;Output : {&#xa;           full_text,&#xa;           metadata&#xa;         }&#xa;&lt;/code&gt;&lt;/pre&gt;" link="&lt;h1&gt;PDF Parser&lt;/h1&gt;&lt;h2&gt;Purpose&lt;/h2&gt;&lt;p&gt;Extracts clean text and metadata from scientific PDFs using PyMuPDF (&lt;code&gt;fitz&lt;/code&gt;) and converts them into a standardized format for downstream chunking and indexing.&lt;/p&gt;&lt;h2&gt;Stack&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;PyMuPDF (&lt;code&gt;fitz&lt;/code&gt;)&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Regex-based text normalization&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Structured logging&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h2&gt;Workflow&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;PDF File&#xa;    ↓&#xa;PyMuPDF&#xa;    ↓&#xa;Page-by-Page Extraction&#xa;    ↓&#xa;Text Normalization&#xa;    ↓&#xa;Metadata Extraction&#xa;    ↓&#xa;Parsed Document&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h2&gt;Parsing Logic&lt;/h2&gt;&lt;h3&gt;1. Open PDF&lt;/h3&gt;&lt;p&gt;Loads PDF using:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;fitz.open(pdf_path)&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h3&gt;2. Extract Metadata&lt;/h3&gt;&lt;p&gt;Reads PDF metadata dictionary:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;title&#xa;author&#xa;page_count&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;Fallbacks:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;title → title or Title&#xa;author → author or Author&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h3&gt;3. Page-by-Page Text Extraction&lt;/h3&gt;&lt;p&gt;Processes pages sequentially to preserve document order.&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;for page in document:&#xa;    page.get_text(&quot;text&quot;)&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h3&gt;4. Text Normalization&lt;/h3&gt;&lt;p&gt;Normalizes extracted text by:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Converting Windows newlines → &lt;code&gt;\n&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Collapsing tabs/multiple spaces → single space&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Reducing 3+ blank lines → 2 blank lines&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Removing leading/trailing whitespace&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;Example:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Raw:&#xa;Text      here&#xa;&#xa;&#xa;&#xa;More text&#xa;&#xa;Normalized:&#xa;Text here&#xa;&#xa;More text&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h3&gt;5. Empty Page Handling&lt;/h3&gt;&lt;p&gt;Skips pages that contain:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;&quot;&quot;&#xa;None&#xa;Whitespace-only content&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h3&gt;6. Merge Pages&lt;/h3&gt;&lt;p&gt;Combines all valid pages:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;full_text = &quot;\n\n&quot;.join(pages_text)&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h2&gt;Output&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;{&#xa;    &quot;full_text&quot;: &quot;...&quot;,&#xa;    &quot;metadata&quot;: {&#xa;        &quot;title&quot;: &quot;...&quot;,&#xa;        &quot;author&quot;: &quot;...&quot;,&#xa;        &quot;page_count&quot;: 12&#xa;    }&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h2&gt;Error Handling&lt;/h2&gt;&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Failure&lt;/th&gt;&lt;th&gt;Action&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;Missing PyMuPDF&lt;/td&gt;&lt;td&gt;RuntimeError&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Missing PDF&lt;/td&gt;&lt;td&gt;FileNotFoundError&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Corrupted PDF&lt;/td&gt;&lt;td&gt;ValueError&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Metadata failure&lt;/td&gt;&lt;td&gt;Continue parsing&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Page load failure&lt;/td&gt;&lt;td&gt;Skip page&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Text extraction failure&lt;/td&gt;&lt;td&gt;Skip page&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;h2&gt;Pipeline Position&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;PDF Upload&#xa;    ↓&#xa;pdf_ingestion.py&#xa;    ↓&#xa;parser.py&#xa;    ↓&#xa;semantic_chunker.py&#xa;    ↓&#xa;embedder.py&#xa;    ↓&#xa;pinecone_upsert.py&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;h2&gt;Design Goals&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Preserve page order&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Extract complete document text&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Remove extraction noise&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Handle malformed PDFs gracefully&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Preserve document metadata&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Produce chunker-ready output&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h2&gt;Current Output Schema&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Input  : PDF File&#xa;Output : {&#xa;           full_text,&#xa;           metadata&#xa;         }&#xa;&lt;/code&gt;&lt;/pre&gt;" id="2_aNJPhvqGcA4EQ-FdMS-1">
          <mxCell parent="1" style="text;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="2340" width="560" x="100" y="140" as="geometry" />
          </mxCell>
        </UserObject>
