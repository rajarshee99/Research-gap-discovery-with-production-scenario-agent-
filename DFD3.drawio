  <diagram id="0roIXQPcwTM-tPmSTgKu" name="Page-4">
    <mxGraphModel dx="872" dy="547" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="&lt;h1&gt;Embedding Service&lt;/h1&gt;&lt;h2&gt;Purpose&lt;/h2&gt;&lt;p&gt;Transforms semantic text chunks into dense vector embeddings suitable for semantic search and Retrieval-Augmented Generation (RAG). The generated embeddings preserve the semantic meaning of each chunk and prepare the data for storage in Pinecone Vector Database.&lt;/p&gt;&lt;hr&gt;&lt;h2&gt;Stack&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;code&gt;sentence-transformers&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;code&gt;SentenceTransformer&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Model: &lt;code&gt;sentence-transformers/all-MiniLM-L6-v2&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Python &lt;code&gt;dataclasses&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;code&gt;functools.lru_cache&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;code&gt;logging&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;hr&gt;&lt;h2&gt;Workflow&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Semantic Chunks&#xa;      ↓&#xa;EmbeddingService&#xa;      ↓&#xa;Load Embedding Model&#xa;      ↓&#xa;Batch Embedding Generation&#xa;      ↓&#xa;Attach Embeddings&#xa;      ↓&#xa;Pinecone Upsert&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;Embedding Logic&lt;/h2&gt;&lt;ol&gt;&lt;li&gt;&lt;p&gt;Receive semantic chunks from &lt;code&gt;semantic_chunker.py&lt;/code&gt;.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Validate each chunk.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Extract chunk text while preserving metadata.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Load the embedding model lazily.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Generate embeddings for all chunk texts in a single batch.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Normalize the embedding output into a consistent list format.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Attach each embedding to its corresponding chunk.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Return enriched chunks ready for Pinecone upsert.&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;p&gt;Example:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Chunk 1&#xa;Chunk 2&#xa;Chunk 3&#xa;      ↓&#xa;SentenceTransformer.encode()&#xa;      ↓&#xa;Embedding 1&#xa;Embedding 2&#xa;Embedding 3&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;Input&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;[&#xa;    {&#xa;        &quot;chunk_id&quot;: &quot;uuid&quot;,&#xa;        &quot;text&quot;: &quot;chunk content&quot;,&#xa;        &quot;metadata&quot;: {&#xa;            &quot;source&quot;: &quot;paper.pdf&quot;,&#xa;            &quot;filename&quot;: &quot;paper.pdf&quot;,&#xa;            &quot;chunk_index&quot;: 0&#xa;        }&#xa;    }&#xa;]&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;Output&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;[&#xa;    {&#xa;        &quot;chunk_id&quot;: &quot;uuid&quot;,&#xa;        &quot;text&quot;: &quot;chunk content&quot;,&#xa;        &quot;embedding&quot;: [0.018, -0.245, 0.367, ...],&#xa;        &quot;metadata&quot;: {&#xa;            &quot;source&quot;: &quot;paper.pdf&quot;,&#xa;            &quot;filename&quot;: &quot;paper.pdf&quot;,&#xa;            &quot;chunk_index&quot;: 0&#xa;        }&#xa;    }&#xa;]&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;Validation Strategy&lt;/h2&gt;&lt;p&gt;Before embedding:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Ignore invalid chunk objects.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Convert non-string text into strings.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Replace missing text with an empty string.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Replace missing metadata with an empty dictionary.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Preserve chunk order.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Preserve chunk identifiers.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;After embedding:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Normalize the model output.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Verify the number of embeddings matches the number of input chunks.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Log warnings if a mismatch occurs.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Return empty embeddings for unmatched chunks if necessary.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;hr&gt;&lt;h2&gt;Lazy Model Loading&lt;/h2&gt;&lt;p&gt;The embedding model is loaded only when required.&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Application Start&#xa;       ↓&#xa;Model Not Loaded&#xa;       ↓&#xa;embed_chunks()&#xa;       ↓&#xa;Load Model&#xa;       ↓&#xa;Reuse Cached Model&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;Benefits:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Faster application startup.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Reduced memory usage.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Model initialized only once.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Cached model reused across multiple embedding requests.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;hr&gt;&lt;h2&gt;Error Handling&lt;/h2&gt;&lt;p&gt;The service handles:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Empty input list.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Invalid chunk objects.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Missing text.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Missing metadata.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Non-string text values.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Model loading failures.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Embedding generation failures.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Embedding count mismatches.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;All unexpected conditions are logged for debugging.&lt;/p&gt;&lt;hr&gt;&lt;h2&gt;Design Goals&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Preserve semantic meaning.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Generate high-quality dense embeddings.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Maintain chunk ordering.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Preserve metadata.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Support efficient batch processing.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Use lazy model initialization.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Cache the embedding model.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Provide robust input validation.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Produce output directly compatible with Pinecone.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;hr&gt;&lt;h2&gt;Configuration&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Embedding Model : sentence-transformers/all-MiniLM-L6-v2&#xa;Embedding Size  : 384 Dimensions&#xa;Batch Size      : 32&#xa;Normalize        : False&#xa;Model Loading    : Lazy&#xa;Caching          : LRU Cache&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;Benefits&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Fast semantic embedding generation.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Efficient batch processing.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Reduced startup overhead through lazy loading.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Ready for Pinecone vector storage.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Preserves document metadata.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Improves semantic retrieval accuracy.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Scalable for large document collections.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Production-ready architecture for RAG pipelines.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;" link="&lt;h1&gt;Embedding Service&lt;/h1&gt;&lt;h2&gt;Purpose&lt;/h2&gt;&lt;p&gt;Transforms semantic text chunks into dense vector embeddings suitable for semantic search and Retrieval-Augmented Generation (RAG). The generated embeddings preserve the semantic meaning of each chunk and prepare the data for storage in Pinecone Vector Database.&lt;/p&gt;&lt;hr&gt;&lt;h2&gt;Stack&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;code&gt;sentence-transformers&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;code&gt;SentenceTransformer&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Model: &lt;code&gt;sentence-transformers/all-MiniLM-L6-v2&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Python &lt;code&gt;dataclasses&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;code&gt;functools.lru_cache&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;code&gt;logging&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;hr&gt;&lt;h2&gt;Workflow&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Semantic Chunks&#xa;      ↓&#xa;EmbeddingService&#xa;      ↓&#xa;Load Embedding Model&#xa;      ↓&#xa;Batch Embedding Generation&#xa;      ↓&#xa;Attach Embeddings&#xa;      ↓&#xa;Pinecone Upsert&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;Embedding Logic&lt;/h2&gt;&lt;ol&gt;&lt;li&gt;&lt;p&gt;Receive semantic chunks from &lt;code&gt;semantic_chunker.py&lt;/code&gt;.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Validate each chunk.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Extract chunk text while preserving metadata.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Load the embedding model lazily.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Generate embeddings for all chunk texts in a single batch.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Normalize the embedding output into a consistent list format.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Attach each embedding to its corresponding chunk.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Return enriched chunks ready for Pinecone upsert.&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;p&gt;Example:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Chunk 1&#xa;Chunk 2&#xa;Chunk 3&#xa;      ↓&#xa;SentenceTransformer.encode()&#xa;      ↓&#xa;Embedding 1&#xa;Embedding 2&#xa;Embedding 3&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;Input&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;[&#xa;    {&#xa;        &quot;chunk_id&quot;: &quot;uuid&quot;,&#xa;        &quot;text&quot;: &quot;chunk content&quot;,&#xa;        &quot;metadata&quot;: {&#xa;            &quot;source&quot;: &quot;paper.pdf&quot;,&#xa;            &quot;filename&quot;: &quot;paper.pdf&quot;,&#xa;            &quot;chunk_index&quot;: 0&#xa;        }&#xa;    }&#xa;]&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;Output&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;[&#xa;    {&#xa;        &quot;chunk_id&quot;: &quot;uuid&quot;,&#xa;        &quot;text&quot;: &quot;chunk content&quot;,&#xa;        &quot;embedding&quot;: [0.018, -0.245, 0.367, ...],&#xa;        &quot;metadata&quot;: {&#xa;            &quot;source&quot;: &quot;paper.pdf&quot;,&#xa;            &quot;filename&quot;: &quot;paper.pdf&quot;,&#xa;            &quot;chunk_index&quot;: 0&#xa;        }&#xa;    }&#xa;]&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;Validation Strategy&lt;/h2&gt;&lt;p&gt;Before embedding:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Ignore invalid chunk objects.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Convert non-string text into strings.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Replace missing text with an empty string.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Replace missing metadata with an empty dictionary.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Preserve chunk order.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Preserve chunk identifiers.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;After embedding:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Normalize the model output.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Verify the number of embeddings matches the number of input chunks.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Log warnings if a mismatch occurs.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Return empty embeddings for unmatched chunks if necessary.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;hr&gt;&lt;h2&gt;Lazy Model Loading&lt;/h2&gt;&lt;p&gt;The embedding model is loaded only when required.&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Application Start&#xa;       ↓&#xa;Model Not Loaded&#xa;       ↓&#xa;embed_chunks()&#xa;       ↓&#xa;Load Model&#xa;       ↓&#xa;Reuse Cached Model&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;Benefits:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Faster application startup.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Reduced memory usage.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Model initialized only once.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Cached model reused across multiple embedding requests.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;hr&gt;&lt;h2&gt;Error Handling&lt;/h2&gt;&lt;p&gt;The service handles:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Empty input list.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Invalid chunk objects.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Missing text.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Missing metadata.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Non-string text values.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Model loading failures.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Embedding generation failures.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Embedding count mismatches.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;All unexpected conditions are logged for debugging.&lt;/p&gt;&lt;hr&gt;&lt;h2&gt;Design Goals&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Preserve semantic meaning.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Generate high-quality dense embeddings.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Maintain chunk ordering.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Preserve metadata.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Support efficient batch processing.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Use lazy model initialization.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Cache the embedding model.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Provide robust input validation.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Produce output directly compatible with Pinecone.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;hr&gt;&lt;h2&gt;Configuration&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Embedding Model : sentence-transformers/all-MiniLM-L6-v2&#xa;Embedding Size  : 384 Dimensions&#xa;Batch Size      : 32&#xa;Normalize        : False&#xa;Model Loading    : Lazy&#xa;Caching          : LRU Cache&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;Benefits&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Fast semantic embedding generation.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Efficient batch processing.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Reduced startup overhead through lazy loading.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Ready for Pinecone vector storage.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Preserves document metadata.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Improves semantic retrieval accuracy.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Scalable for large document collections.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Production-ready architecture for RAG pipelines.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;" id="xEk603g_fekyqTzeyaZh-1">
          <mxCell parent="1" style="text;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="3250" width="560" x="10" y="170" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="BChLRrLimSYlcV3z_UP1" name="Page-5">
    <mxGraphModel dx="872" dy="547" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="&lt;h1&gt;Pinecone Upsert Service&lt;/h1&gt;&lt;h2&gt;Purpose&lt;/h2&gt;&lt;p&gt;Stores embedded semantic document chunks into the Pinecone Vector Database for efficient semantic similarity search and Retrieval-Augmented Generation (RAG). The service validates embeddings, organizes vectors into document-specific namespaces, batches upload operations, and records upload statistics while preserving document metadata.&lt;/p&gt;&lt;hr&gt;&lt;h2&gt;Stack&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;code&gt;pinecone&lt;/code&gt; Python SDK (v9.x)&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Pinecone Vector Database&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Python &lt;code&gt;dataclasses&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Python &lt;code&gt;logging&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Python &lt;code&gt;pathlib&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Python &lt;code&gt;typing&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Python &lt;code&gt;uuid&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Batch Upsert API&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;hr&gt;&lt;h2&gt;Workflow&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Embedded Chunks&#xa;       ↓&#xa;PineconeUpsertService&#xa;       ↓&#xa;Read API Key&#xa;       ↓&#xa;Connect to Pinecone&#xa;       ↓&#xa;Verify Index Exists&#xa;       ↓&#xa;Validate Chunks&#xa;       ↓&#xa;Generate Namespace&#xa;       ↓&#xa;Prepare Vector Payloads&#xa;       ↓&#xa;Batch Upsert&#xa;       ↓&#xa;Return Upload Statistics&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;Upsert Logic&lt;/h2&gt;&lt;ol&gt;&lt;li&gt;&lt;p&gt;Receive embedded chunks from &lt;code&gt;embedder.py&lt;/code&gt;.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Load the Pinecone API key securely from &lt;code&gt;api_keys.txt&lt;/code&gt;.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Connect to the Pinecone control-plane client.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Verify that the configured index exists.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Validate every embedded chunk.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Validate embedding dimensions (384).&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Generate a namespace from the document filename.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Fall back to the document title if the filename is unavailable.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Use a UUID namespace only as a final fallback.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Build Pinecone vector payloads.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Preserve document metadata.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Ensure retrieval text is stored in metadata.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Truncate long text fields to satisfy Pinecone metadata size limits.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Group vectors by namespace.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Upload vectors in batches.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Return upload statistics for monitoring.&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;hr&gt;&lt;h2&gt;Namespace Generation Strategy&lt;/h2&gt;&lt;p&gt;The service automatically groups all chunks belonging to the same research paper into a single namespace.&lt;/p&gt;&lt;p&gt;Priority order:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;metadata[&quot;filename&quot;]&#xa;        ↓&#xa;metadata[&quot;title&quot;]&#xa;        ↓&#xa;Random UUID (fallback)&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;Example:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Artificial_Endocrine_System.pdf&#xa;        ↓&#xa;Namespace:&#xa;Artificial_Endocrine_System&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;This enables document-level organization and efficient retrieval.&lt;/p&gt;&lt;hr&gt;&lt;h2&gt;Input&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;[&#xa;    {&#xa;        &quot;chunk_id&quot;: &quot;uuid&quot;,&#xa;        &quot;text&quot;: &quot;semantic chunk&quot;,&#xa;        &quot;embedding&quot;: [...384 values...],&#xa;        &quot;metadata&quot;: {&#xa;            &quot;filename&quot;: &quot;paper.pdf&quot;,&#xa;            &quot;source&quot;: &quot;upload&quot;,&#xa;            &quot;title&quot;: &quot;...&quot;,&#xa;            &quot;author&quot;: &quot;...&quot;,&#xa;            &quot;chunk_index&quot;: 0&#xa;        }&#xa;    }&#xa;]&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;Output&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;{&#xa;    &quot;total_input_chunks&quot;: 42,&#xa;    &quot;total_uploaded_vectors&quot;: 42,&#xa;    &quot;skipped_invalid_vectors&quot;: 0,&#xa;    &quot;per_namespace&quot;: {&#xa;        &quot;paper&quot;: 42&#xa;    }&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;Validation Strategy&lt;/h2&gt;&lt;p&gt;Before upload:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Validate chunk object structure.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Validate chunk identifier.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Validate embedding existence.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Validate embedding dimension (384).&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Convert embeddings into floating-point lists.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Replace missing metadata with an empty dictionary.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Skip malformed vectors without interrupting processing.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;During upload:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Group vectors by namespace.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Batch vectors before upload.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Catch Pinecone upload failures.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Report namespace-specific upload statistics.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;hr&gt;&lt;h2&gt;Metadata Handling&lt;/h2&gt;&lt;p&gt;Each uploaded vector preserves document metadata including:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;filename&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;source&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;title&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;author&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;page_count&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;chunk_index&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;The service also stores the chunk text for downstream retrieval while truncating oversized text fields to remain within Pinecone&#39;s metadata limits.&lt;/p&gt;&lt;hr&gt;&lt;h2&gt;Batch Processing&lt;/h2&gt;&lt;p&gt;Vectors are uploaded in configurable batches.&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Batch Size: 100&#xa;&#xa;Vectors&#xa;    ↓&#xa;Batch 1&#xa;Batch 2&#xa;Batch 3&#xa;    ↓&#xa;Pinecone&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;Batch processing reduces network overhead and improves scalability for large document collections.&lt;/p&gt;&lt;hr&gt;&lt;h2&gt;Error Handling&lt;/h2&gt;&lt;p&gt;The service detects and handles:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Missing API key.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Invalid API key.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Missing Pinecone index.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Invalid chunk objects.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Missing metadata.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Missing embeddings.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Incorrect embedding dimensions.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Namespace generation failures.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Pinecone upload exceptions.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Metadata size violations.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;All unexpected errors are logged and propagated with descriptive runtime exceptions.&lt;/p&gt;&lt;hr&gt;&lt;h2&gt;Design Goals&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Automated vector storage.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Document-level namespace organization.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Metadata preservation.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Efficient batch uploads.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Secure credential management.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Embedding validation.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Pinecone compatibility.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Scalable ingestion for large document collections.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Production-ready error handling.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;hr&gt;&lt;h2&gt;Configuration&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Index Name           : researchassistant&#xa;Embedding Dimension  : 384&#xa;Similarity Metric    : Cosine&#xa;Batch Size           : 100&#xa;Metadata Text Limit  : 8000 Characters&#xa;Namespace Strategy   : Filename → Title → UUID&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;Benefits&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Fully automated Pinecone ingestion pipeline.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Consistent document namespaces.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Fast batch vector uploads.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Reliable embedding validation.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Metadata preserved for downstream retrieval.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Compatible with semantic search and RAG workflows.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Scalable architecture for thousands of research papers.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Production-ready vector storage service with robust validation and monitoring.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;" link="&lt;h1&gt;Pinecone Upsert Service&lt;/h1&gt;&lt;h2&gt;Purpose&lt;/h2&gt;&lt;p&gt;Stores embedded semantic document chunks into the Pinecone Vector Database for efficient semantic similarity search and Retrieval-Augmented Generation (RAG). The service validates embeddings, organizes vectors into document-specific namespaces, batches upload operations, and records upload statistics while preserving document metadata.&lt;/p&gt;&lt;hr&gt;&lt;h2&gt;Stack&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;code&gt;pinecone&lt;/code&gt; Python SDK (v9.x)&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Pinecone Vector Database&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Python &lt;code&gt;dataclasses&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Python &lt;code&gt;logging&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Python &lt;code&gt;pathlib&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Python &lt;code&gt;typing&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Python &lt;code&gt;uuid&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Batch Upsert API&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;hr&gt;&lt;h2&gt;Workflow&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Embedded Chunks&#xa;       ↓&#xa;PineconeUpsertService&#xa;       ↓&#xa;Read API Key&#xa;       ↓&#xa;Connect to Pinecone&#xa;       ↓&#xa;Verify Index Exists&#xa;       ↓&#xa;Validate Chunks&#xa;       ↓&#xa;Generate Namespace&#xa;       ↓&#xa;Prepare Vector Payloads&#xa;       ↓&#xa;Batch Upsert&#xa;       ↓&#xa;Return Upload Statistics&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;Upsert Logic&lt;/h2&gt;&lt;ol&gt;&lt;li&gt;&lt;p&gt;Receive embedded chunks from &lt;code&gt;embedder.py&lt;/code&gt;.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Load the Pinecone API key securely from &lt;code&gt;api_keys.txt&lt;/code&gt;.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Connect to the Pinecone control-plane client.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Verify that the configured index exists.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Validate every embedded chunk.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Validate embedding dimensions (384).&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Generate a namespace from the document filename.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Fall back to the document title if the filename is unavailable.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Use a UUID namespace only as a final fallback.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Build Pinecone vector payloads.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Preserve document metadata.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Ensure retrieval text is stored in metadata.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Truncate long text fields to satisfy Pinecone metadata size limits.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Group vectors by namespace.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Upload vectors in batches.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Return upload statistics for monitoring.&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;hr&gt;&lt;h2&gt;Namespace Generation Strategy&lt;/h2&gt;&lt;p&gt;The service automatically groups all chunks belonging to the same research paper into a single namespace.&lt;/p&gt;&lt;p&gt;Priority order:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;metadata[&quot;filename&quot;]&#xa;        ↓&#xa;metadata[&quot;title&quot;]&#xa;        ↓&#xa;Random UUID (fallback)&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;Example:&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Artificial_Endocrine_System.pdf&#xa;        ↓&#xa;Namespace:&#xa;Artificial_Endocrine_System&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;This enables document-level organization and efficient retrieval.&lt;/p&gt;&lt;hr&gt;&lt;h2&gt;Input&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;[&#xa;    {&#xa;        &quot;chunk_id&quot;: &quot;uuid&quot;,&#xa;        &quot;text&quot;: &quot;semantic chunk&quot;,&#xa;        &quot;embedding&quot;: [...384 values...],&#xa;        &quot;metadata&quot;: {&#xa;            &quot;filename&quot;: &quot;paper.pdf&quot;,&#xa;            &quot;source&quot;: &quot;upload&quot;,&#xa;            &quot;title&quot;: &quot;...&quot;,&#xa;            &quot;author&quot;: &quot;...&quot;,&#xa;            &quot;chunk_index&quot;: 0&#xa;        }&#xa;    }&#xa;]&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;Output&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;{&#xa;    &quot;total_input_chunks&quot;: 42,&#xa;    &quot;total_uploaded_vectors&quot;: 42,&#xa;    &quot;skipped_invalid_vectors&quot;: 0,&#xa;    &quot;per_namespace&quot;: {&#xa;        &quot;paper&quot;: 42&#xa;    }&#xa;}&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;Validation Strategy&lt;/h2&gt;&lt;p&gt;Before upload:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Validate chunk object structure.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Validate chunk identifier.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Validate embedding existence.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Validate embedding dimension (384).&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Convert embeddings into floating-point lists.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Replace missing metadata with an empty dictionary.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Skip malformed vectors without interrupting processing.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;During upload:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Group vectors by namespace.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Batch vectors before upload.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Catch Pinecone upload failures.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Report namespace-specific upload statistics.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;hr&gt;&lt;h2&gt;Metadata Handling&lt;/h2&gt;&lt;p&gt;Each uploaded vector preserves document metadata including:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;filename&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;source&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;title&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;author&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;page_count&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;chunk_index&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;The service also stores the chunk text for downstream retrieval while truncating oversized text fields to remain within Pinecone&#39;s metadata limits.&lt;/p&gt;&lt;hr&gt;&lt;h2&gt;Batch Processing&lt;/h2&gt;&lt;p&gt;Vectors are uploaded in configurable batches.&lt;/p&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Batch Size: 100&#xa;&#xa;Vectors&#xa;    ↓&#xa;Batch 1&#xa;Batch 2&#xa;Batch 3&#xa;    ↓&#xa;Pinecone&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;Batch processing reduces network overhead and improves scalability for large document collections.&lt;/p&gt;&lt;hr&gt;&lt;h2&gt;Error Handling&lt;/h2&gt;&lt;p&gt;The service detects and handles:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Missing API key.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Invalid API key.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Missing Pinecone index.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Invalid chunk objects.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Missing metadata.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Missing embeddings.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Incorrect embedding dimensions.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Namespace generation failures.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Pinecone upload exceptions.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Metadata size violations.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;All unexpected errors are logged and propagated with descriptive runtime exceptions.&lt;/p&gt;&lt;hr&gt;&lt;h2&gt;Design Goals&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Automated vector storage.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Document-level namespace organization.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Metadata preservation.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Efficient batch uploads.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Secure credential management.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Embedding validation.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Pinecone compatibility.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Scalable ingestion for large document collections.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Production-ready error handling.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;hr&gt;&lt;h2&gt;Configuration&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-text&quot;&gt;Index Name           : researchassistant&#xa;Embedding Dimension  : 384&#xa;Similarity Metric    : Cosine&#xa;Batch Size           : 100&#xa;Metadata Text Limit  : 8000 Characters&#xa;Namespace Strategy   : Filename → Title → UUID&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;hr&gt;&lt;h2&gt;Benefits&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Fully automated Pinecone ingestion pipeline.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Consistent document namespaces.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Fast batch vector uploads.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Reliable embedding validation.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Metadata preserved for downstream retrieval.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Compatible with semantic search and RAG workflows.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Scalable architecture for thousands of research papers.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Production-ready vector storage service with robust validation and monitoring.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;" id="lyQpQd0ZVG3UIes6bkOE-1">
          <mxCell parent="1" style="text;whiteSpace=wrap;html=1;" vertex="1">
            <mxGeometry height="4060" width="560" x="20" y="320" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
